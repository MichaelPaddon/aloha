FROM debian:trixie-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
        curl \
        python3 \
        libpam0g \
        libpam-runtime \
        passwd \
        slapd \
        ldap-utils \
    && rm -rf /var/lib/apt/lists/*

COPY target/release/aloha /usr/bin/aloha
COPY tests/integration/ /opt/tests/
RUN chmod +x /opt/tests/run.sh /usr/bin/aloha

CMD ["/opt/tests/run.sh"]
